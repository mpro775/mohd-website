NODE_ENV=development
PORT=3000

MONGODB_URI=mongodb://localhost:27017/mohd-portfolio

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRATION=7d

CORS_ORIGINS=http://localhost:3001,http://localhost:5173

THROTTLE_TTL=60
THROTTLE_LIMIT=100

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
CONTACT_MAIL_TO=

R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=mohd-portfolio-files
R2_PUBLIC_URL=https://files.example.com
