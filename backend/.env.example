NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/mohd-portfolio
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

THROTTLE_TTL=60
THROTTLE_LIMIT=100

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
CONTACT_MAIL_TO=
CONTACT_TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
CONTACT_SPAM_WORDS=casino,crypto,viagra,loan,forex


SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=

R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=mohd-portfolio-files
R2_PUBLIC_URL=https://files.example.com
R2_REGION=auto

# Blog CMS privacy and cache invalidation
ANALYTICS_HASH_SALT=replace-with-a-long-random-secret
FRONTEND_REVALIDATE_URL=http://localhost:3001/api/revalidate
FRONTEND_REVALIDATE_SECRET=replace-with-the-same-secret-as-frontend
